# ── Google Cloud / Vertex AI ───────────────────────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-west1

# ── ADK model configuration ───────────────────────────────────────────────
# Tell ADK to use Vertex AI (not the Gemini API). Required for RAG corpus access.
GOOGLE_GENAI_USE_VERTEXAI=TRUE
# If using Vertex AI, authenticate via: gcloud auth application-default login
# If using Gemini API instead, set GOOGLE_GENAI_USE_VERTEXAI=FALSE and uncomment:
# GOOGLE_GENAI_API_KEY=your-api-key

# Fast model for planning and intent extraction (low-latency)
GEN_FAST_MODEL=gemini-2.0-flash
# Advanced model for RAG retrieval, evaluation, and research (default: gemini-2.5-flash)
GEN_ADVANCED_MODEL=gemini-2.5-flash
# Report model used only for the final report composer (default: gemini-2.5-pro)
GEN_REPORT_MODEL=gemini-2.5-pro

# ── RAG corpus ────────────────────────────────────────────────────────────
# Full Vertex AI RAG corpus resource name
# Format: projects/<PROJECT>/locations/<LOCATION>/ragCorpora/<CORPUS_ID>
RAG_CORPUS=projects/your-gcp-project-id/locations/us-west1/ragCorpora/your-corpus-id

# ── API Key ───────────────────────────────────────────────────────────────
# Secret key required in the x-api-key header for all requests.
API_KEY=your-api-key-here

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * to allow all.
ALLOWED_ORIGINS=*

# ── Service Account Key (for non-GCP environments like Vercel) ───────────
# JSON key for a GCP service account. Used by gcp-auth.ts to authenticate
# when ADC (gcloud auth application-default login) is not available.
# Generate with: gcloud iam service-accounts keys create key.json --iam-account=YOUR_SA@YOUR_PROJECT.iam.gserviceaccount.com
# Then minify: cat key.json | python3 -c "import sys,json; print(json.dumps(json.load(sys.stdin), separators=(',',':')))"
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...","...":"..."}
