# Google Cloud project ID
GCP_PROJECT=your-gcp-project-id

# Vertex AI location (default: us-central1)
GCP_LOCATION=us-central1

# Gemini model to use for the simple /api/chat endpoint (default: gemini-1.5-pro)
GEMINI_MODEL=gemini-1.5-pro

# ── Deep research agent models (/api/research) ────────────────────────────
# Fast model used by the IntentExtractor agent (default: gemini-2.0-flash)
GEN_FAST_MODEL=gemini-2.0-flash

# Advanced model used by the RagRetriever and Synthesizer agents (default: gemini-2.5-pro)
GEN_ADVANCED_MODEL=gemini-2.5-pro

# Full Vertex AI RAG corpus resource name
# Format: projects/<PROJECT>/locations/<LOCATION>/ragCorpora/<CORPUS_ID>
RAG_CORPUS=projects/your-gcp-project-id/locations/us-central1/ragCorpora/your-corpus-id

# Comma-separated list of allowed CORS origins. Use * to allow all origins.
ALLOWED_ORIGINS=*
